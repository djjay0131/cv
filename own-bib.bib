@misc{cusati2026papers,
  author = {Jason Cusati and Chris Brown},
  title = {From Papers to Progress: Rethinking Knowledge Accumulation in Software Engineering},
  year = {2026},
  url = {https://arxiv.org/abs/2604.16208},
  doi = {10.1145/3793657.3793888},
  abstract = {Software engineering research faces challenges in accumulating and integrating knowledge effectively. The authors analyzed responses from 280 experienced researchers at ICSE 2026, identifying tensions between growing research output and inadequate mechanisms for synthesizing results. They identified four structural issues: papers function as isolated knowledge units with claims embedded in prose; context is lost during publication; claims evolve without tracking; and incentive structures prioritize novelty over consolidation. The paper proposes four principles for improving research artifacts: structured representations of claims and evidence; documented methodological decisions with provenance; long-lived and reusable substrates; and governance aligning individual incentives with collective knowledge-building. The authors discuss implications for research practice and community infrastructure supporting cumulative scientific progress.},
  note = {Preprint; final publication forthcoming as ICSE 2026 paper}
}
